# -------------------------
# Reusable snippets
# -------------------------

(preprod_auth) {
  basicauth {
    admin {$CADDY_ADMIN_HASH}
  }
}

# Generic reverse proxy
(rp) {
  reverse_proxy {args.0}
  encode gzip
}

# Reverse proxy with auth
(rp_preprod) {
  route {
    import preprod_auth
    reverse_proxy {args.0}
  }
  encode gzip
}

# Static site
(static) {
  root * {args.0}
  file_server
  encode gzip
}

# Static site with auth
(static_preprod) {
  route {
    import preprod_auth
    root * {args.0}
    file_server
  }
  encode gzip
}

# -------------------------
# Landing page
# -------------------------

engineerfamily.net {
  import static /srv/landing
}

preprod.engineerfamily.net {
  import static_preprod /srv/landing
}

# -------------------------
# Siddharth app
# -------------------------

siddharth.engineerfamily.net {
  import rp siddharth:8000
}

siddharth-preprod.engineerfamily.net {
  import rp_preprod siddharth-preprod:8000
}

# -------------------------
# Suryan app (Streamlit)
# -------------------------

suryan.engineerfamily.net {
  reverse_proxy suryan:8501
  encode gzip
}

suryan-preprod.engineerfamily.net {
  route {
    import preprod_auth
    reverse_proxy suryan-preprod:8501
  }
  encode gzip
}

# -------------------------
# Shivam static
# -------------------------

shivam.engineerfamily.net {
  root * /srv/shivam/public
  file_server
  header /assets/* Cache-Control "public, max-age=31536000, immutable"
  encode gzip
}

shivam-preprod.engineerfamily.net {
  import static_preprod /srv/shivam/public
}

# -------------------------
# Nivi (Ghost)
# -------------------------

nivi.engineerfamily.net {
  import rp nivi:2368
}

nivi-preprod.engineerfamily.net {
  import rp_preprod nivi-preprod:2368
}

# -------------------------
# Analytics (always protected)
# -------------------------

analytics.engineerfamily.net {
  route {
    basicauth {
      admin {$CADDY_ADMIN_HASH}
    }
    reverse_proxy analytics:3000
  }
}