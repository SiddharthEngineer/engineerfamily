engineerfamily.net {
  root * /srv/landing
  file_server
  encode gzip
}

siddharth.engineerfamily.net {
  reverse_proxy siddharth:8000
  encode gzip
}

siddharth.preprod.engineerfamily.net {
  import preprod_auth
  reverse_proxy engineerfamily-preprod-siddharth-1:8000
  encode gzip
}

suryan.engineerfamily.net {
  reverse_proxy suryan:8501
  @websocket {
    header Connection *Upgrade*
    header Upgrade websocket
  }
  reverse_proxy @websocket suryan:8501
  encode gzip
}

suryan.preprod.engineerfamily.net {
  import preprod_auth
  reverse_proxy engineerfamily-preprod-suryan-1:8501
  @websocket {
    header Connection *Upgrade*
    header Upgrade websocket
  }
  reverse_proxy @websocket engineerfamily-preprod-suryan-1:8501
}

