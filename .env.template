# ─────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in values
# NEVER commit .env to git (it's in .gitignore)
# Store production values as GitHub Actions Secrets
# ─────────────────────────────────────────────────────────

# ─── Django (siddharth) ───────────────────────────────────
SIDDHARTH_SECRET_KEY=change-me-to-a-long-random-string
SIDDHARTH_SECRET_KEY_PREPROD=change-me-preprod
DJANGO_ENV=production

# ─── Ghost (nivi) ──────────────────────────────────────────
# Free SMTP: use Mailgun, Brevo, or Gmail app password
GHOST_SMTP_HOST=smtp.mailgun.org
GHOST_SMTP_PORT=587
GHOST_SMTP_USER=postmaster@engineerfamily.net
GHOST_SMTP_PASS=your-smtp-password

# ─── Umami Analytics ──────────────────────────────────────
UMAMI_DB_PASSWORD=change-me-strong-db-password
# Generate with: openssl rand -base64 32
UMAMI_APP_SECRET=change-me-random-secret