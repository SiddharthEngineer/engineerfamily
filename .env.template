# ─────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in values
# NEVER commit .env to git (it's in .gitignore)
# Store production values as GitHub Actions Secrets
# ─────────────────────────────────────────────────────────

# ─── Umami Analytics ──────────────────────────────────────
# Dashboard first-login defaults on a fresh DB are admin / umami.
# Change password after first login from Umami Settings -> Profile.
# Variables below are runtime secrets, not dashboard username/password.
UMAMI_DB_PASSWORD=

# Generate with: openssl rand -base64 32
UMAMI_APP_SECRET=

# Website ID used by the main Vite site tracker (build-time value).
UMAMI_HOST=https://analytics.engineerfamily.net
UMAMI_APP_ID=
UMAMI_STREAMLIT_ID=

# ─── Caddy Hash Password ─────────────────────────────────
plaintextpassword=
CADDY_ADMIN_HASH=